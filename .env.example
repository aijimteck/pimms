# URL réelle de prise de rendez-vous médiateur social
MEDIATOR_URL=https://reference-url-citation.invalid/0

# Mot de passe d'administration.
# Si cette variable est absente, un mot de passe est généré automatiquement
# dans instance/admin_password.txt au premier lancement.
# ADMIN_PASSWORD=

# Clé secrète de session Flask.
# Si cette variable est absente, une clé est générée automatiquement
# dans instance/secret_key.txt au premier lancement.
# SECRET_KEY=
